<script>
// ============================================
// LOGICA DI CALCOLO
// ============================================

function getValoreKwp(kWp, tipo) {
  if (tipo === 'B') {
    if (kWp <= 20) return 1420;
    if (kWp <= 200) return 1120;
    if (kWp <= 600) return 1020;
    if (kWp <= 1000) return 910;
    return 840;
  }
  if (tipo === 'C') {
    if (kWp <= 20) return 1500;
    if (kWp <= 200) return 1200;
    if (kWp <= 600) return 1100;
    if (kWp <= 1000) return 1000;
    return 940;
  }
  return 0;
}

function calcola() {
  const matBeni = parseFloat(document.getElementById('matBeni').value) || 0;
  const immBeni = parseFloat(document.getElementById('immBeni').value) || 0;
  const kWp = parseFloat(document.getElementById('kwp').value) || 0;
  const tipoPV = document.getElementById('tipoPV').value;
  const costoPVReale = parseFloat(document.getElementById('costoPV').value) || 0;
  const coefAmm = (parseFloat(document.getElementById('coefAmm').value) || 0) / 100;
  const ires = (parseFloat(document.getElementById('ires').value) || 0) / 100;

  // A. Capping PV
  const valoreKwp = getValoreKwp(kWp, tipoPV);
  const capPV = kWp * valoreKwp;
  const importoAmmPV = (kWp > 0 && tipoPV)
    ? (costoPVReale > 0 ? Math.min(costoPVReale, capPV) : capPV)
    : 0;

  // B. Plafond scaglioni
  const totale = matBeni + immBeni + importoAmmPV;
  const sc1 = Math.min(totale, 2_500_000);
  const sc2 = Math.min(Math.max(totale - 2_500_000, 0), 7_500_000);
  const sc3 = Math.min(Math.max(totale - 10_000_000, 0), 10_000_000);

  // C. Maggiorazione
  const m1 = sc1 * 1.8;
  const m2 = sc2 * 1.0;
  const m3 = sc3 * 0.5;
  const magg = m1 + m2 + m3;

  // D. Risparmio fiscale
  const risp = magg * ires;

  // Step 4: Cash flow anno-per-anno
  const anni = coefAmm > 0 ? Math.max(1, Math.round(1 / coefAmm)) : 0;
  const annuo = anni > 0 ? risp / anni : 0;

  return {
    matBeni, immBeni, kWp, tipoPV, costoPVReale, coefAmm, ires,
    valoreKwp, capPV, importoAmmPV,
    totale, sc1, sc2, sc3, m1, m2, m3, magg, risp,
    anni, annuo
  };
}

// ============================================
// RENDER UI
// ============================================

const fmt = n => '€ ' + Math.round(n).toLocaleString('it-IT');

function pulse(el) {
  el.classList.remove('num-pulse');
  void el.offsetWidth;
  el.classList.add('num-pulse');
}

function render() {
  const r = calcola();

  // Risultati principali
  const els = {
    bigResult: fmt(r.risp),
    bigMagg: fmt(r.magg),
    rTotale: fmt(r.totale),
    rSc1: fmt(r.m1),
    rSc2: fmt(r.m2),
    rSc3: fmt(r.m3),
    rMagg: fmt(r.magg),
  };
  Object.keys(els).forEach(id => {
    const el = document.getElementById(id);
    if (el && el.textContent !== els[id]) {
      el.textContent = els[id];
      pulse(el);
    }
  });

  // PV cap hint
  const pvHint = document.getElementById('pvCapHint');
  const pvPlaceholder = document.getElementById('pvCapPlaceholder');
  if (r.kWp > 0 && r.tipoPV) {
    pvHint.classList.remove('hidden');
    pvPlaceholder.classList.add('hidden');
    document.getElementById('pvCapValue').textContent = fmt(r.capPV);
    document.getElementById('pvAmmValue').textContent = fmt(r.importoAmmPV);
  } else {
    pvHint.classList.add('hidden');
    pvPlaceholder.classList.remove('hidden');
  }

  // Cash flow
  const cashList = document.getElementById('cashFlowList');
  const annuiVal = document.getElementById('annuiVal');
  annuiVal.textContent = r.anni || '—';

  if (r.anni > 0 && r.annuo > 0) {
    const currentYear = 2026;
    let html = '';
    for (let i = 0; i < r.anni; i++) {
      const anno = currentYear + i;
      const pct = (100 / r.anni).toFixed(1);
      html += `
        <div class="flex justify-between items-center py-1.5 border-b border-slate-100 last:border-0">
          <span class="text-slate-700"><span class="font-semibold">Anno ${anno}</span> <span class="text-xs text-slate-400 ml-1">${pct}%</span></span>
          <span class="font-semibold text-m-navy">${fmt(r.annuo)}</span>
        </div>
      `;
    }
    cashList.innerHTML = html;
  } else {
    cashList.innerHTML = '<div class="text-sm text-slate-500 py-3 text-center">Inserisci il coefficiente di ammortamento (Step 4) per vedere il piano annuale.</div>';
  }

  // Progress bar
  const filled = [
    r.matBeni > 0,
    r.immBeni > 0,
    (r.kWp > 0 && r.tipoPV) || true, // step 3 opzionale
    r.coefAmm > 0
  ].filter(Boolean).length;
  const completed = [
    r.matBeni > 0,
    r.immBeni > 0,
    r.kWp > 0 && r.tipoPV,
    r.coefAmm > 0
  ].filter(Boolean).length;
  const progress = (completed / 4) * 100;
  document.getElementById('progressBar').style.width = progress + '%';
  document.getElementById('progressText').textContent = completed + '/4';

  // Active step (focus → glow)
  // (gestito da focus event sotto)

  return r;
}

// ============================================
// EVENTI
// ============================================

const inputIds = ['matBeni', 'immBeni', 'kwp', 'tipoPV', 'costoPV', 'coefAmm', 'ires'];
inputIds.forEach(id => {
  const el = document.getElementById(id);
  el.addEventListener('input', render);
  el.addEventListener('change', render);
  el.addEventListener('focus', () => {
    document.querySelectorAll('.step-card').forEach(c => c.classList.remove('is-active'));
    const stepNum =
      id === 'matBeni' ? 1 :
      id === 'immBeni' ? 2 :
      ['kwp','tipoPV','costoPV'].includes(id) ? 3 : 4;
    document.getElementById('step' + stepNum)?.classList.add('is-active');
  });
});

// ============================================
// PDF DOWNLOAD
// ============================================

document.getElementById('downloadBtn').addEventListener('click', () => {
  const r = calcola();
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF({ unit: 'mm', format: 'a4' });

  const orange = [255, 79, 0];
  const navy = [10, 31, 68];
  const gray = [107, 114, 128];

  let y = 20;

  // Header brand
  doc.setFillColor(...navy);
  doc.rect(0, 0, 210, 12, 'F');
  doc.setTextColor(255, 255, 255);
  doc.setFont('helvetica', 'bold');
  doc.setFontSize(10);
  doc.text('MUFFIN  ·  La finanza agevolata smart', 14, 8);

  y = 24;
  // Title
  doc.setTextColor(...navy);
  doc.setFont('helvetica', 'bold');
  doc.setFontSize(18);
  doc.text('Stima Iperammortamento 2026', 14, y);
  y += 6;
  doc.setFont('helvetica', 'normal');
  doc.setFontSize(9);
  doc.setTextColor(...gray);
  const dataStr = new Date().toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' });
  doc.text('Generato il ' + dataStr + ' · Riferimento: L. 199/2025 art. 1 commi 427-436', 14, y);
  y += 10;

  // Risultato grande
  doc.setFillColor(255, 241, 235);
  doc.roundedRect(14, y, 182, 26, 3, 3, 'F');
  doc.setTextColor(...gray);
  doc.setFontSize(8);
  doc.setFont('helvetica', 'bold');
  doc.text('RISPARMIO FISCALE STIMATO (IRES ' + (r.ires*100).toFixed(0) + '%)', 18, y + 7);
  doc.setTextColor(...orange);
  doc.setFontSize(22);
  doc.setFont('helvetica', 'bold');
  doc.text(fmt(r.risp), 18, y + 18);
  doc.setTextColor(...navy);
  doc.setFontSize(9);
  doc.setFont('helvetica', 'normal');
  doc.text('su ' + fmt(r.magg) + ' di maggiorazione totale deducibile', 18, y + 23);
  y += 32;

  // Sezione: Input
  doc.setTextColor(...navy);
  doc.setFontSize(11);
  doc.setFont('helvetica', 'bold');
  doc.text('Input dell\'analisi', 14, y);
  y += 2;
  doc.setDrawColor(...orange);
  doc.setLineWidth(0.5);
  doc.line(14, y, 60, y);
  y += 6;

  doc.setFontSize(9);
  doc.setFont('helvetica', 'normal');
  const inputRows = [
    ['Beni Materiali 4.0', fmt(r.matBeni)],
    ['Beni Immateriali 4.0', fmt(r.immBeni)],
    ['Fotovoltaico kWp', r.kWp ? r.kWp.toLocaleString('it-IT') + ' kWp · Tipologia ' + (r.tipoPV || '—') : '—'],
    ['Costo PV reale (input)', r.costoPVReale > 0 ? fmt(r.costoPVReale) : 'non specificato (usato cap)'],
    ['Importo PV ammissibile', fmt(r.importoAmmPV)],
    ['Coefficiente ammortamento', (r.coefAmm * 100).toFixed(1) + '% (' + (r.anni || '—') + ' anni)'],
    ['Aliquota IRES', (r.ires * 100).toFixed(1) + '%'],
  ];
  inputRows.forEach(([label, value]) => {
    doc.setTextColor(...gray);
    doc.text(label, 14, y);
    doc.setTextColor(...navy);
    doc.setFont('helvetica', 'bold');
    doc.text(value, 196, y, { align: 'right' });
    doc.setFont('helvetica', 'normal');
    y += 5.5;
  });
  y += 4;

  // Sezione: Calcolo scaglioni
  doc.setTextColor(...navy);
  doc.setFontSize(11);
  doc.setFont('helvetica', 'bold');
  doc.text('Calcolo per scaglioni', 14, y);
  y += 2;
  doc.line(14, y, 60, y);
  y += 6;

  doc.setFontSize(9);
  doc.setFont('helvetica', 'normal');
  doc.setTextColor(...gray);
  doc.text('Investimento totale agevolabile', 14, y);
  doc.setTextColor(...navy);
  doc.setFont('helvetica', 'bold');
  doc.text(fmt(r.totale), 196, y, { align: 'right' });
  doc.setFont('helvetica', 'normal');
  y += 7;

  const scRows = [
    ['1ª fascia · 180% (≤ 2,5M)', fmt(r.sc1), fmt(r.m1)],
    ['2ª fascia · 100% (2,5M-10M)', fmt(r.sc2), fmt(r.m2)],
    ['3ª fascia · 50% (10M-20M)', fmt(r.sc3), fmt(r.m3)],
  ];
  doc.setFillColor(245, 246, 248);
  doc.rect(14, y - 4, 182, 5, 'F');
  doc.setTextColor(...gray);
  doc.setFontSize(8);
  doc.text('Fascia', 16, y);
  doc.text('Base imponibile', 110, y, { align: 'right' });
  doc.text('Maggiorazione', 196, y, { align: 'right' });
  y += 6;
  doc.setFontSize(9);
  scRows.forEach(([label, base, magg]) => {
    doc.setTextColor(...navy);
    doc.text(label, 16, y);
    doc.text(base, 110, y, { align: 'right' });
    doc.setFont('helvetica', 'bold');
    doc.setTextColor(...orange);
    doc.text(magg, 196, y, { align: 'right' });
    doc.setFont('helvetica', 'normal');
    y += 5.5;
  });
  y += 1;
  doc.setDrawColor(...gray);
  doc.setLineWidth(0.2);
  doc.line(14, y, 196, y);
  y += 4;
  doc.setTextColor(...navy);
  doc.setFont('helvetica', 'bold');
  doc.setFontSize(10);
  doc.text('Maggiorazione totale', 14, y);
  doc.setTextColor(...orange);
  doc.text(fmt(r.magg), 196, y, { align: 'right' });
  y += 8;

  // Sezione: Cash flow (se calcolato)
  if (r.anni > 0 && r.annuo > 0) {
    doc.setTextColor(...navy);
    doc.setFontSize(11);
    doc.setFont('helvetica', 'bold');
    doc.text('Piano cash-flow (lineare)', 14, y);
    y += 2;
    doc.setDrawColor(...orange);
    doc.line(14, y, 60, y);
    y += 6;
    doc.setFontSize(9);
    doc.setFont('helvetica', 'normal');
    const startY = 2026;
    for (let i = 0; i < r.anni; i++) {
      doc.setTextColor(...gray);
      doc.text('Anno ' + (startY + i), 14, y);
      doc.setTextColor(...navy);
      doc.setFont('helvetica', 'bold');
      doc.text(fmt(r.annuo), 196, y, { align: 'right' });
      doc.setFont('helvetica', 'normal');
      y += 5.5;
    }
    y += 4;
  }

  // Disclaimer
  if (y > 250) { doc.addPage(); y = 20; }
  doc.setTextColor(...gray);
  doc.setFontSize(8);
  doc.setFont('helvetica', 'italic');
  const disclaimer = 'Stima indicativa. Importi eccedenti euro 20M annuali non sono agevolabili. Il piano cash-flow assume distribuzione lineare e non considera la riduzione 50% dell\'ammortamento ordinario del primo anno (l\'iperammortamento non subisce dimezzamento). Per il calcolo definitivo serve perizia tecnica e certificazione contabile. Documento informativo, non sostituisce parere del consulente di riferimento.';
  const splitDisc = doc.splitTextToSize(disclaimer, 182);
  doc.text(splitDisc, 14, y);

  // Footer
  doc.setTextColor(...navy);
  doc.setFontSize(8);
  doc.setFont('helvetica', 'normal');
  doc.text('muffin.io  ·  La finanza agevolata smart', 14, 290);

  doc.save('Stima-Iperammortamento-Muffin.pdf');
});

// Init
render();
</script>

